<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Serif+Display&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        h1, h2 { font-family: 'DM Serif Display', serif; }
        input:focus { outline: none; }
        .line-input {
            background: transparent;
            border: none;
            border-bottom: 1.5px solid #d1d5db;
            border-radius: 0;
            padding: 8px 0;
            width: 100%;
            font-size: 0.95rem;
            color: #1f2937;
            transition: border-color 0.2s;
        }
        .line-input:focus {
            border-bottom-color: #1f2937;
        }
        .line-input::placeholder {
            color: #9ca3af;
            font-weight: 300;
        }
    </style>
</head>
<body class="bg-stone-50 min-h-screen flex">

    <!-- Left decorative panel -->
    <div class="hidden lg:flex w-1/2 bg-stone-900 flex-col justify-between p-16">
        <div>
            <span class="text-stone-400 text-sm tracking-widest uppercase">System</span>
        </div>
        <div>
            <h1 class="text-white text-5xl leading-tight mb-6">Create<br/>Account.</h1>
            <p class="text-stone-400 text-sm leading-relaxed max-w-xs">
                Join today. It only takes a moment to get started.
            </p>
        </div>
        <div>
            <p class="text-stone-600 text-xs">© 2025</p>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="flex-1 flex items-center justify-center p-8 sm:p-16">
        <div class="w-full max-w-sm">

            <!-- Mobile header -->
            <div class="lg:hidden mb-10">
                <h2 class="text-3xl text-stone-900">Create Account.</h2>
            </div>

            <p class="text-stone-400 text-xs tracking-widest uppercase mb-10">Register</p>

            <!-- Error -->
            <% if (error) { %>
            <div class="mb-6 text-red-500 text-sm border-l-2 border-red-400 pl-3">
                <%= error %>
            </div>
            <% } %>

            <form action="/api/register" method="POST" class="space-y-8">

                <div>
                    <label class="block text-xs text-stone-400 uppercase tracking-widest mb-3">Username</label>
                    <input type="text" name="username" required placeholder="yourname" class="line-input">
                </div>

                <div>
                    <label class="block text-xs text-stone-400 uppercase tracking-widest mb-3">Email</label>
                    <input type="email" name="email" required placeholder="your@email.com" class="line-input">
                </div>

                <div>
                    <label class="block text-xs text-stone-400 uppercase tracking-widest mb-3">Password</label>
                    <input type="password" name="password" required minlength="6" placeholder="Min. 6 characters" class="line-input">
                </div>

                <button type="submit"
                    class="w-full bg-stone-900 text-white text-sm tracking-widest uppercase py-3.5 hover:bg-stone-700 transition duration-200">
                    Create Account →
                </button>
            </form>

            <p class="text-stone-400 text-sm mt-8">
                Already have an account?
                <a href="/login" class="text-stone-900 underline underline-offset-4 hover:text-stone-600">Sign in</a>
            </p>

        </div>
    </div>

</body>
</html>
