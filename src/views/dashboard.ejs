<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Serif+Display&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        h1, h2, h3 { font-family: 'DM Serif Display', serif; }
    </style>
</head>
<body class="bg-stone-50 min-h-screen">

    <!-- Nav -->
    <nav class="border-b border-stone-200 bg-stone-50">
        <div class="max-w-4xl mx-auto px-8 h-14 flex items-center justify-between">
            <span class="text-xs text-stone-400 tracking-widest uppercase">System</span>
            <a href="/login"
               class="text-xs text-stone-400 tracking-widest uppercase hover:text-stone-900 transition duration-200">
                Sign Out →
            </a>
        </div>
    </nav>

    <!-- Content -->
    <div class="max-w-4xl mx-auto px-8 py-16">

        <!-- Greeting -->
        <div class="mb-16">
            <p class="text-xs text-stone-400 uppercase tracking-widest mb-3">Dashboard</p>
            <h2 class="text-4xl sm:text-5xl text-stone-900">Hello, <%= username %>.</h2>
        </div>

        <!-- Status cards -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-stone-200">

            <div class="bg-stone-50 p-8">
                <p class="text-xs text-stone-400 uppercase tracking-widest mb-4">Status</p>
                <p class="text-stone-900 text-sm">Active</p>
            </div>

            <div class="bg-stone-50 p-8">
                <p class="text-xs text-stone-400 uppercase tracking-widest mb-4">Member Since</p>
                <p class="text-stone-900 text-sm"><%= new Date().toLocaleDateString('en-US', {year:'numeric', month:'long', day:'numeric'}) %></p>
            </div>

            <div class="bg-stone-50 p-8">
                <p class="text-xs text-stone-400 uppercase tracking-widest mb-4">Account</p>
                <p class="text-stone-900 text-sm">Standard</p>
            </div>

        </div>

        <!-- Divider -->
        <div class="border-t border-stone-200 mt-16 pt-8">
            <p class="text-stone-400 text-sm">You are signed in successfully.</p>
        </div>

    </div>

</body>
</html>
